{
  "expo": {
    "name": "HANURI",
    "slug": "hanuri",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "hanuri",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF6B6B"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.hanuri.app",
      "infoPlist": {
        "NSUserNotificationUsageDescription": "매일 한국어 학습 리마인더를 받으세요.",
        "NSMicrophoneUsageDescription": "발음 연습을 위해 마이크를 사용합니다.",
        "NSSpeechRecognitionUsageDescription": "발음 채점을 위해 음성 인식을 사용합니다."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.hanuri.app",
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#FF6B6B",
          "sounds": []
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "발음 연습을 위해 마이크를 사용합니다."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "a31c6f44-af34-4a61-9a96-8e04d20a2d60"
      }
    }
  }
}
